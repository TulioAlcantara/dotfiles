{
  "agent_servers": {
    "claude": {
      "default_mode": "default",
      "default_model": "haiku",
      "favorite_models": [],
      "default_config_options": {},
      "favorite_config_option_values": {},
    },
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": false,
      "settings": {},
    },
    "postgres-context-server": {
      "enabled": true,
      "settings": {},
    },
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
  },
  "buffer_line_height": "standard",
  "base_keymap": "VSCode",
  "gutter": {
    "line_numbers": true,
  },
  "auto_indent_on_paste": true,
  "show_whitespaces": "none",
  "soft_wrap": "editor_width",
  "tab_size": 2,
  "terminal": {
    "font_family": "ZedMono Nerd Font Propo",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "debugger": {
    "dock": "left",
  },
  "git_panel": {
    "dock": "left",
  },
  "project_panel": {
    "dock": "left",
  },
  "edit_predictions": {
    "provider": "zed",
    "disabled_globs": [],
    "mode": "eager",
  },
  "icon_theme": "Material Icon Theme",
  "tab_bar": {
    "show_nav_history_buttons": false,
    "show": true,
  },
  "minimap": {
    "show": "never",
    "display_in": null,
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "play_sound_when_agent_done": true,
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4",
    },
    "default_profile": "write",
    "dock": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
  },
  "vim_mode": true,
  "cursor_blink": true,
  "ui_font_family": "Hack Nerd Font Propo",
  "ui_font_size": 16.0,
  "ui_font_weight": 400.0,
  "buffer_font_family": "ZedMono Nerd Font Propo",
  "buffer_font_size": 18.0,
  "agent_ui_font_size": 16.0,
  "buffer_font_weight": 350.0,
  "relative_line_numbers": "wrapped",
  "theme": "BlackFox",
  "format_on_save": "on",
  "languages": {
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": ["biome", "format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": ["biome", "format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },
    "TSX": {
      "formatter": {
        "external": {
          "command": "npx",
          "arguments": ["biome", "format", "--stdin-file-path", "{buffer_path}"],
        },
      },
    },
  },
}
